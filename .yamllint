---
extends: default

ignore: |
  k8s/cilium/charts/
  k8s/helm/kube-prometheus-stack.values.yaml
  k8s/helm/minecraft.values.yaml
  k8s/helm/rcon-web.values.yaml
  k8s/cilium/manifests/
  k8s/cilium/cilium.values.yaml
  monitoring.yml
  docs/
  darwin-arm64/
  .ansible/

rules:
  braces:
    max-spaces-inside: 1
  brackets:
    max-spaces-inside: 1
  comments:
    min-spaces-from-content: 1
  line-length: {max: 180, level: warning}
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  truthy: {level: warning}
  indentation: {level: error}
  trailing-spaces: {level: error}
  new-line-at-end-of-file: {level: error}
  document-start: {level: warning}
